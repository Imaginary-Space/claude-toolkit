{
  "$comment": "Routines ignore interactive permission prompts—hooks enforce destructive-command policy.",
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(rg *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  },
  "env": {
    "CLAUDE_TOOLKIT_ROOT": "${CLAUDE_PROJECT_DIR}",
    "GOOGLE_SERVICE_ACCOUNT_JSON_B64": "",
    "GOOGLE_DRIVE_PRESENTATIONS_FOLDER_ID": "1zFR2oMJNQ4E8B0cuIqgOe4jTXNstcgB4",
    "FAL_AI_API_KEY": "26e1f8fe-dac0-4543-aaf4-9472106befce:72e8b9b8bbc5ff07470e55d5d492e1d7"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(rm *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/deny-dangerous.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/run-remote-setup.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/scripts/session-start-banner.sh"
          }
        ]
      }
    ]
  }
}
